# 应用基础配置
# 开发/测试/生产通过修改本文件或复制为 .env.production 快速切换
APP_ENV=development
DEBUG=true
TZ=Asia/Shanghai

# CORS 白名单，多个来源用英文逗号分隔；生产环境请勿使用 *
CORS_ORIGINS=*

# PostgreSQL 数据库（PostgreSQL + asyncpg）
# 示例开发数据库：postgresql+asyncpg://outfit:outfit@localhost:5432/outfit_db
# 示例生产数据库：postgresql+asyncpg://outfit:outfit@<生产IP>:5432/outfit_db
DATABASE_URL=postgresql+asyncpg://outfit:outfit@localhost:5432/outfit_db

# JWT
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# 微信小程序登录
WECHAT_APPID=your-wechat-miniprogram-appid
WECHAT_SECRET=your-wechat-miniprogram-secret
# 仅本地开发且无微信密钥时开启，生产必须 false
WECHAT_DEV_FALLBACK=false

# 腾讯云 COS（前端直传 STS）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-bucket-name-1234567890
COS_REGION=ap-guangzhou
COS_DURATION_SECONDS=1800
COS_ALLOW_PREFIX=users/*

# AI 大模型（衣物识别 / 搭配推荐 / 购前分析）
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-vl-max

# 阿里云虚拟试衣
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-secret
ALIYUN_TRYON_ENDPOINT=https://facebody.cn-shanghai.aliyuncs.com

# 阿里云百炼 / DashScope 虚拟试衣（OutfitAnyone）
# fast=aitryon, premium=aitryon-plus
TRYON_API_KEY=your-tryon-api-key
TRYON_BASE_URL=https://dashscope.aliyuncs.com/api/v1
TRYON_FAST_MODEL=aitryon
TRYON_PREMIUM_MODEL=aitryon-plus

# 阿里云百炼 / DashScope 图像分割抠图（拼图功能用）
# 官方模型：aitryon-parsing-v1，端点：/services/vision/image-process/process
# 默认与 TRYON_API_KEY 相同，也可单独配置
TRYON_SEGMENT_API_KEY=your-tryon-api-key
TRYON_SEGMENT_BASE_URL=https://dashscope.aliyuncs.com/api/v1
TRYON_SEGMENT_MODEL=aitryon-parsing-v1

# 功能开关与运营推广
# 非会员每日免费次数，默认 0；推广期可临时调大
FEATURE_FREE_TRYON_DAILY_LIMIT=0
FEATURE_FREE_PUZZLE_DAILY_LIMIT=0
PROMOTION_MODE=false

# 积分过期
SIGN_IN_REWARD_BASE=5
SIGN_IN_REWARD_MAX=20
SIGN_IN_REWARD_EXPIRE_DAYS=30
# 购买积分包过期时间（默认 60 天，过期后直接清零）
CREDIT_PURCHASE_EXPIRE_DAYS=60

# 功能单次消耗积分（会员额度用完后或非会员）
TRYON_CREDIT_COST=10
PUZZLE_CREDIT_COST=5

# 邀请返利奖励积分
REFERRAL_REGISTER_REWARD_CREDITS=50
REFERRAL_PURCHASE_REWARD_CREDITS=100
